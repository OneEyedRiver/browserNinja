<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg1">

    <!-- ── Master character image ── -->
    <ImageView
        android:id="@+id/master_img"
        android:layout_width="200dp"
        android:layout_height="500dp"
        android:src="@drawable/img_3"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:visibility="gone" />

    <!-- ── Level-up flash labels ── -->
    <TextView
        android:id="@+id/txtLevelUp1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LEVEL UP!"
        android:textSize="32sp"
        android:textStyle="bold"
        android:fontFamily="@font/orbitron_bold"
        android:letterSpacing="0.15"
        android:textColor="#FFD700"
        android:shadowColor="#FFAA00"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="18"
        android:visibility="gone" />

    <TextView
        android:id="@+id/txtLevelUp2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NEW LEVEL!"
        android:textSize="32sp"
        android:textStyle="bold"
        android:fontFamily="@font/orbitron_bold"
        android:letterSpacing="0.15"
        android:textColor="#FF4444"
        android:shadowColor="#FF0000"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="18"
        android:visibility="gone" />

    <TextView
        android:id="@+id/txtLevelUp3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GET READY!"
        android:textSize="32sp"
        android:textStyle="bold"
        android:fontFamily="@font/orbitron_bold"
        android:letterSpacing="0.15"
        android:textColor="#00FFCC"
        android:shadowColor="#00FFB2"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="18"
        android:visibility="gone" />

    <!-- ── Browser / enemy icons ── -->
    <ImageView
        android:id="@+id/chromeImg"
        android:layout_width="96dp"
        android:layout_height="106dp"
        android:src="@drawable/chrome" />

    <ImageView
        android:id="@+id/edgeImg"
        android:layout_width="96dp"
        android:layout_height="106dp"
        android:src="@drawable/edge"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/fireFoxImg"
        android:layout_width="96dp"
        android:layout_height="106dp"
        android:src="@drawable/firefox"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/braveImg"
        android:layout_width="96dp"
        android:layout_height="106dp"
        android:src="@drawable/brave"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/torImg"
        android:layout_width="96dp"
        android:layout_height="106dp"
        android:src="@drawable/tor"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/safariImg"
        android:layout_width="96dp"
        android:layout_height="106dp"
        android:src="@drawable/safari"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/operaImg"
        android:layout_width="96dp"
        android:layout_height="106dp"
        android:src="@drawable/opera"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/explorerImg"
        android:layout_width="96dp"
        android:layout_height="106dp"
        android:src="@drawable/explorer"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/virusImg"
        android:layout_width="96dp"
        android:layout_height="106dp"
        android:src="@drawable/virus"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/virusImg1"
        android:layout_width="96dp"
        android:layout_height="106dp"
        android:src="@drawable/virus"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/virusImg2"
        android:layout_width="96dp"
        android:layout_height="106dp"
        android:src="@drawable/virus3"
        android:visibility="gone" />


    <!-- ══════════════════════════════════════
         HUD PILL: ❤ LIVES  (top-left)
    ══════════════════════════════════════ -->

    <LinearLayout
        android:id="@+id/hudLifeCard"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/hud_life_bg"
        android:paddingStart="12dp"
        android:paddingEnd="16dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_marginStart="12dp"
        android:layout_marginTop="52dp"

        >

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="❤"
            android:textSize="15sp"
            android:layout_marginEnd="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HP"
            android:textSize="9sp"
            android:textStyle="bold"
            android:fontFamily="@font/orbitron_bold"
            android:textColor="#99FF8888"
            android:letterSpacing="0.10"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/lifeDetect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/orbitron_bold"
            android:textColor="#FF4444"
            android:shadowColor="#FF0000"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="12" />

    </LinearLayout>

    <!-- ══════════════════════════════════════
         HUD PILL: ⚡ LEVEL  (below lives pill)
    ══════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/hudLevelCard"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/hud_level_bg"
        android:paddingStart="12dp"
        android:paddingEnd="16dp"
        android:layout_alignParentStart="true"
        android:layout_below="@id/hudLifeCard"
        android:layout_marginStart="12dp"
        android:layout_marginTop="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡"
            android:textSize="15sp"
            android:layout_marginEnd="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:textSize="9sp"
            android:textStyle="bold"
            android:fontFamily="@font/orbitron_bold"
            android:textColor="#99FFDD88"
            android:letterSpacing="0.10"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/txtLevel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/orbitron_bold"
            android:textColor="#FFD700"
            android:shadowColor="#FFAA00"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="12" />

    </LinearLayout>
    <LinearLayout
        android:id="@+id/hudScoreCard"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_marginStart="15dp"
        android:layout_marginTop="145dp"
        android:background="@drawable/hud_score_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="16dp"

        >

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:layout_marginEnd="6dp"
            android:textSize="15sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:fontFamily="@font/orbitron_bold"
            android:letterSpacing="0.10"
            android:text="Score"
            android:textColor="#99FF8888"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/scoreText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/orbitron_bold"
            android:shadowColor="#FF0000"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="12"
            android:text="0"
            android:textColor="#FF4444"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- ══════════════════════════════════════
         MAIN MENU  (center)
    ══════════════════════════════════════ -->

    <EditText
        android:id="@+id/edtName"
        android:layout_width="220dp"
        android:layout_height="56dp"
        android:textSize="18sp"
        android:fontFamily="@font/orbitron_bold"
        android:textColor="#FFFFFF"
        android:textColorHint="#80FFFFFF"
        android:hint="Enter Name"
        android:background="@drawable/edt_modern_bg"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_centerInParent="true"
        android:visibility="invisible"
        android:inputType="textPersonName"
        android:maxLines="1" />

    <Button
        android:id="@+id/btnEnter"
        android:layout_width="220dp"
        android:layout_height="56dp"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="@font/orbitron_bold"
        android:text="ENTER"
        android:textColor="#0A0A1A"
        android:letterSpacing="0.12"
        android:background="@drawable/btn_primary_bg"
        android:layout_below="@id/edtName"
        android:layout_centerInParent="true"
        android:layout_marginTop="20dp"
        android:visibility="invisible"
        android:stateListAnimator="@null"
        android:elevation="6dp" />

    <Button
        android:id="@+id/btnPlay"
        android:layout_width="220dp"
        android:layout_height="56dp"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="@font/orbitron_bold"
        android:text="▶  PLAY"
        android:textColor="#9C27B0"
        android:letterSpacing="0.12"
        android:background="@drawable/hud_level_bg"
        android:layout_below="@id/edtName"
        android:layout_centerInParent="true"
        android:layout_marginTop="10dp"
        android:stateListAnimator="@null"
        android:elevation="6dp" />

    <Button
        android:id="@+id/btnRank"
        android:layout_width="220dp"
        android:layout_height="56dp"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="@font/orbitron_bold"
        android:text="🏆  RANK"
        android:textColor="#FFD700"
        android:letterSpacing="0.12"
        android:background="@drawable/btn_secondary_bg"
        android:layout_below="@id/btnPlay"
        android:layout_centerInParent="true"
        android:layout_marginTop="10dp"
        android:stateListAnimator="@null"
        android:elevation="4dp" />

    <Button
        android:id="@+id/btnRestart"
        android:layout_width="220dp"
        android:layout_height="56dp"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="@font/orbitron_bold"
        android:text="↺  RESTART"
        android:textColor="#00FFCC"
        android:letterSpacing="0.12"
        android:background="@drawable/btn_ghost_bg"
        android:layout_below="@id/btnRank"
        android:layout_centerInParent="true"
        android:layout_marginTop="10dp"
        android:visibility="invisible"
        android:stateListAnimator="@null"
        android:elevation="4dp" />

    <TableLayout
        android:id="@+id/tableRank"
        android:layout_width="260dp"
        android:layout_height="wrap_content"
        android:layout_below="@id/btnRestart"
        android:layout_centerInParent="true"
        android:layout_marginTop="12dp"
        android:stretchColumns="*"
        android:visibility="gone"
        android:background="@drawable/hud_score_bg"
        android:padding="8dp">

        <TableRow>

            <TextView
                android:text="Rank"
                android:textStyle="bold"
                android:textColor="#FFD700"
                android:padding="4dp"/>

            <TextView
                android:text="Name"
                android:textStyle="bold"
                android:textColor="#FFD700"
                android:padding="4dp"/>

            <TextView
                android:text="Score"
                android:textStyle="bold"
                android:textColor="#FFD700"
                android:padding="4dp"/>

        </TableRow>

    </TableLayout>

    <!-- ── Pause button (top-right, below score) ── -->
    <Button
        android:id="@+id/btnPause"
        android:layout_width="120dp"
        android:layout_height="40dp"
        android:textSize="10sp"
        android:textStyle="bold"
        android:fontFamily="@font/orbitron_bold"
        android:text="⏸  PAUSE"
        android:textColor="#CCFFFFFF"
        android:letterSpacing="0.10"
        android:background="@drawable/btn_ghost_bg"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:layout_marginTop="50dp"
        android:layout_marginEnd="12dp"
        android:visibility="invisible"
        android:stateListAnimator="@null"
        android:elevation="4dp" />

    <!-- ── Countdown overlay ── -->
    <TextView
        android:id="@+id/txtCountdown"
        android:layout_width="200dp"
        android:layout_height="60dp"
        android:textSize="52sp"
        android:textStyle="bold"
        android:fontFamily="@font/orbitron_bold"
        android:text="GO!"
        android:textColor="#FF4444"
        android:shadowColor="#FF0000"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="24"
        android:letterSpacing="0.1"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:visibility="gone" />

    <!-- ── Slash overlay (always on top) ── -->
    <com.example.gameact.SlashView
        android:id="@+id/slashView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</RelativeLayout>