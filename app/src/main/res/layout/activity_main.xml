<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
android:id="@+id/rootLayout"

    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg1">
    <ImageView
        android:id="@+id/master_img"
        android:layout_width="200dp"
        android:layout_height="500dp"
        android:textSize="30dp"
        android:src="@drawable/img_3"

        android:layout_centerInParent="true"
        android:gravity="center"
        android:visibility="gone"



        />

    <TextView
        android:id="@+id/txtLevelUp1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LEVEL UP!"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFD700"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/txtLevelUp2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NEW LEVEL!"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FF4444"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/txtLevelUp3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GET READY!"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#00FFCC"
        android:visibility="gone"/>



    <ImageView
        android:id="@+id/chromeImg"
        android:layout_width="96dp"
        android:layout_height="106dp"

        android:src="@drawable/chrome"



        />
    <ImageView
        android:id="@+id/edgeImg"
        android:layout_width="96dp"
        android:layout_height="106dp"

        android:src="@drawable/edge"

        android:visibility="gone"

        />
    <ImageView
        android:id="@+id/fireFoxImg"
        android:layout_width="96dp"
        android:layout_height="106dp"

        android:src="@drawable/firefox"

        android:visibility="gone"

        />

    <ImageView
        android:id="@+id/braveImg"
        android:layout_width="96dp"
        android:layout_height="106dp"
        android:src="@drawable/brave"
        android:visibility="gone"
        />
    <ImageView
        android:id="@+id/torImg"
        android:layout_width="96dp"
        android:layout_height="106dp"
        android:src="@drawable/tor"
        android:visibility="gone"
        />

    <ImageView
        android:id="@+id/safariImg"
        android:layout_width="96dp"
        android:layout_height="106dp"
        android:src="@drawable/safari"
        android:visibility="gone"
        />
    <ImageView
        android:id="@+id/operaImg"
        android:layout_width="96dp"
        android:layout_height="106dp"
        android:src="@drawable/opera"
        android:visibility="gone"
        />
    <ImageView
        android:id="@+id/explorerImg"
        android:layout_width="96dp"
        android:layout_height="106dp"
        android:src="@drawable/explorer"
        android:visibility="gone"
        />



    <ImageView
        android:id="@+id/virusImg"
        android:layout_width="96dp"
        android:layout_height="106dp"

        android:src="@drawable/virus"

        android:visibility="gone"

        />
    <ImageView
        android:id="@+id/virusImg1"
        android:layout_width="96dp"
        android:layout_height="106dp"
        android:src="@drawable/virus"
        android:visibility="gone"
        />
    <ImageView
        android:id="@+id/virusImg2"
        android:layout_width="96dp"
        android:layout_height="106dp"
        android:src="@drawable/virus3"
        android:visibility="gone"
        />
    <TextView
        android:id="@+id/hitDetect"
        android:layout_width="96dp"
        android:layout_height="106dp"


        android:layout_marginBottom="0dp"
        android:text="No Hit"
        ></TextView>


    <TextView
        android:id="@+id/lifeDetect"
        android:layout_width="40dp"
        android:layout_height="25dp"

        android:layout_below="@id/hitDetect"
        android:layout_marginBottom="0dp"
        android:text="3"
        ></TextView>

    <TextView
        android:id="@+id/txtLevel"
        android:layout_width="90dp"
        android:layout_height="25dp"

        android:layout_below="@id/lifeDetect"
        android:layout_marginBottom="0dp"
        android:text="1"
        ></TextView>

    <TextView

        android:id="@+id/scoreText"
        android:layout_width="96dp"
        android:layout_height="106dp"

        android:layout_marginBottom="0dp"

        android:textSize="50dp"
        ></TextView>

    <EditText

        android:id="@+id/edtName"
        android:layout_width="200dp"
        android:layout_height="60dp"
        android:textSize="30dp"

        android:layout_marginBottom="0dp"
    android:hint="Enter Name"

        android:layout_centerInParent="true"
        android:visibility="invisible"
        ></EditText>

    <Button
        android:id="@+id/btnEnter"
        android:layout_width="200dp"
        android:layout_height="60dp"
        android:textSize="30dp"
        android:layout_below="@id/edtName"
        android:text="Enter"
        android:layout_centerInParent="true"
        android:visibility="invisible"
        />
    <Button
        android:id="@+id/btnPlay"
        android:layout_width="200dp"
        android:layout_height="60dp"
        android:textSize="30dp"
        android:layout_below="@id/edtName"
        android:text="Play"
        android:layout_centerInParent="true"
        />
    <Button
        android:id="@+id/btnRank"
        android:layout_width="200dp"
        android:layout_height="60dp"
        android:textSize="30dp"
        android:layout_below="@id/btnPlay"
        android:text="Rank"
        android:layout_centerInParent="true"
        />
    <Button
        android:id="@+id/btnRestart"
        android:layout_width="200dp"
        android:layout_height="60dp"
        android:textSize="30dp"
        android:layout_below="@id/btnRank"
        android:text="Restart"
        android:layout_centerInParent="true"
        android:visibility="invisible"
        />
    <TextView
        android:id="@+id/txtRank"
        android:layout_width="200dp"
        android:layout_height="60dp"
        android:textSize="10dp"
        android:layout_below="@id/btnRestart"
        android:layout_centerInParent="true"

        ></TextView>
    <Button
        android:id="@+id/btnPause"
        android:layout_width="90dp"
        android:layout_height="40dp"
        android:layout_below="@id/edtName"
        android:text="Pause"
        android:layout_alignParentRight="true"
        android:layout_alignParentTop="true"
        android:textSize="10dp"
        android:layout_marginTop="30dp"
        android:visibility="invisible"

        />

    <TextView
        android:id="@+id/txtCountdown"
        android:layout_width="200dp"
        android:layout_height="60dp"
        android:textSize="30dp"
        android:text="GO!"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:textColor="#FF0000"
        android:visibility="gone"


        />


    <com.example.gameact.SlashView
        android:id="@+id/slashView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"

        />


</RelativeLayout>