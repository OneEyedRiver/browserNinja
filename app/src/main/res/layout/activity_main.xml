<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
android:id="@+id/rootLayout"

    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/explorerImg"
        android:layout_width="96dp"
        android:layout_height="106dp"
        android:layout_centerInParent="true"
        android:src="@drawable/explorere"
        android:visibility="gone"

        />

    <ImageView
        android:id="@+id/chromeImg"
        android:layout_width="96dp"
        android:layout_height="106dp"

        android:src="@drawable/chrome"




        />

    <ImageView
        android:id="@+id/edgeImg"
        android:layout_width="96dp"
        android:layout_height="106dp"

        android:src="@drawable/edge"

        android:visibility="gone"

        />
    <ImageView
        android:id="@+id/fireFoxImg"
        android:layout_width="96dp"
        android:layout_height="106dp"

        android:src="@drawable/firefox"

        android:visibility="gone"

        />

    <ImageView
        android:id="@+id/braveImg"
        android:layout_width="96dp"
        android:layout_height="106dp"

        android:src="@drawable/brave"

        android:visibility="gone"

        />

    <ImageView
        android:id="@+id/virusImg"
        android:layout_width="96dp"
        android:layout_height="106dp"

        android:src="@drawable/virus"

        android:visibility="gone"

        />
    <TextView
        android:id="@+id/hitDetect"
        android:layout_width="96dp"
        android:layout_height="106dp"


        android:layout_marginBottom="0dp"
        android:text="No Hit"
        ></TextView>


    <TextView
        android:id="@+id/lifeDetect"
        android:layout_width="96dp"
        android:layout_height="106dp"

        android:layout_below="@id/hitDetect"
        android:layout_marginBottom="0dp"
        android:text="3"
        ></TextView>


    <TextView

        android:id="@+id/scoreText"
        android:layout_width="96dp"
        android:layout_height="106dp"

        android:layout_marginBottom="0dp"

        android:textSize="50dp"
        ></TextView>

    <EditText

        android:id="@+id/edtName"
        android:layout_width="300dp"
        android:layout_height="106dp"


    android:hint="Enter Name"
        android:textSize="50dp"
        android:layout_centerInParent="true"
        android:visibility="gone"
        ></EditText>

    <Button
        android:id="@+id/btnEnter"
        android:layout_width="300dp"
        android:layout_height="106dp"
        android:layout_below="@id/edtName"
        android:text="Enter"
        android:layout_centerInParent="true"
       android:textSize="50dp"
        android:visibility="gone"
        />

    <Button
        android:id="@+id/btnPlay"
        android:layout_width="300dp"
        android:layout_height="75dp"
        android:layout_below="@id/edtName"
        android:text="Play"
        android:layout_centerInParent="true"
        android:textSize="50dp"

        /><Button
    android:id="@+id/btnResult"
    android:layout_width="300dp"
    android:layout_height="75dp"
    android:layout_below="@id/btnPlay"
    android:text="Rank"
    android:layout_centerInParent="true"
    android:textSize="30dp"


    />
    <TextView
        android:id="@+id/txtResult"
        android:layout_width="300dp"
        android:layout_height="106dp"
        android:layout_below="@id/btnResult"
        android:layout_centerInParent="true"
        ></TextView>

    <com.example.gameact.SlashView
        android:id="@+id/slashView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />


</RelativeLayout>